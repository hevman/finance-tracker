# ─────────────────────────────────────────────
#  finance-tracker — database configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Choose one: sqlite | postgresql | mysql | mssql
DB_CLIENT=sqlite

# SQLite — path to database file (only for sqlite)
DB_FILENAME=./finance.db

# PostgreSQL / MySQL / MSSQL connection (ignored when using sqlite)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=finance_user
DB_PASSWORD=secret
DB_NAME=finance_tracker

# Default currency for new transactions (e.g. USD, EUR, GBP)
DB_DEFAULT_CURRENCY=USD
