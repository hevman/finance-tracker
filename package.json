{
  "name": "finance-tracker-cli",
  "version": "1.0.0",
  "description": "A personal finance tracker CLI supporting SQLite, PostgreSQL, MySQL and MSSQL.",
  "main": "dist/index.js",
  "bin": {
    "finance": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "finance",
    "cli",
    "budget",
    "tracker",
    "sqlite",
    "postgresql",
    "mysql",
    "mssql",
    "typescript"
  ],
  "author": "hevman",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "knex": "^3.1.0",
    "better-sqlite3": "^11.1.2"
  },
  "optionalDependencies": {
    "pg": "^8.12.0",
    "mysql2": "^3.10.0",
    "tedious": "^18.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
